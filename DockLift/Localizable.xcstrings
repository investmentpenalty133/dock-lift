    "Moving a window onto the active Mission Control Space has no public API. DockLift optionally loads undocumented SkyLight symbols at runtime and falls back to Accessibility-only behaviour when they are missing." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moving a window onto the active Mission Control Space has no public API. DockLift optionally loads undocumented SkyLight symbols at runtime and falls back to Accessibility-only behaviour when they are missing."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将窗口移到当前调度中心空间没有公开 API。DockLift 会在运行时可选加载未文档化的 SkyLight 符号；若不可用则回退为仅使用辅助功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將視窗移到目前 Mission Control 空間沒有公開 API。DockLift 會在執行時可選載入未文件化的 SkyLight 符號；若不可用則回退為僅使用輔助使用。"
          }
        }
      }
    },
