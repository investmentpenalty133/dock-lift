    "DockLift needs Accessibility access to read window lists and raise windows belonging to other apps." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift needs Accessibility access to read window lists and raise windows belonging to other apps."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 需要辅助功能权限，以读取窗口列表并提升其他应用的窗口。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 需要輔助使用權限，以讀取視窗列表並提升其他 App 的視窗。"
          }
        }
      }
    },
    "DockLift needs Accessibility before you can open Settings or lift windows." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift needs Accessibility before you can open Settings or lift windows."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在打开设置或提升窗口之前，DockLift 需要辅助功能权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在打開設定或提升視窗之前，DockLift 需要輔助使用權限。"
          }
        }
      }
    },
    "DockLift will not lift windows for these apps. Drag an .app here, choose one from disk, pick a running app, or type a bundle identifier. Finder and DockLift are ignored by default." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift will not lift windows for these apps. Drag an .app here, choose one from disk, pick a running app, or type a bundle identifier. Finder and DockLift are ignored by default."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 不会为这些应用提升窗口。可将 .app 拖到此处、从磁盘选择、从正在运行的应用中选取，或手动输入 Bundle 标识符。默认忽略“访达”和 DockLift 自身。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 不會為這些 App 提升視窗。可將 .app 拖到此處、從磁碟選擇、從正在執行的 App 中選取，或手動輸入 Bundle 識別碼。預設忽略「Finder」與 DockLift 本身。"
          }
        }
      }
    },
    "DockLift will not lift windows for these bundle identifiers. Finder and DockLift itself are ignored by default." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift will not lift windows for these bundle identifiers. Finder and DockLift itself are ignored by default."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 不会为这些 Bundle 标识符提升窗口。默认忽略“访达”和 DockLift 自身。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DockLift 不會為這些 Bundle 識別碼提升視窗。預設忽略「Finder」與 DockLift 本身。"
          }
        }
      }
    },
