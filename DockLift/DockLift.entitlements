<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  DockLift must control other apps' windows via Accessibility.
	  App Sandbox prevents that for third-party processes, so it is intentionally off.
	  Hardened Runtime remains enabled at the target level.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
